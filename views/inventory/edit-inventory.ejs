<% if (title) { %>
<h1><%= title %></h1>
<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/update-inventory" method="post" class="form-container">
  <div class="form-group">
    <label for="classificationList">Classification <span class="required">*</span></label>
    <%- classificationSelect %>
  </div>

  <div class="form-group">
    <label for="invMake">Make <span class="required">*</span></label>
    <input type="text" id="invMake" name="inv_make" value="<%= locals.inv_make || '' %>" required>
  </div>

  <div class="form-group">
    <label for="invModel">Model <span class="required">*</span></label>
    <input type="text" id="invModel" name="inv_model" value="<%= locals.inv_model || '' %>" required>
  </div>

  <div class="form-group">
    <label for="invYear">Year <span class="required">*</span></label>
    <input type="number" id="invYear" name="inv_year" value="<%= locals.inv_year || '' %>" required min="1900" max="2099">
  </div>

  <div class="form-group">
    <label for="invDescription">Description <span class="required">*</span></label>
    <textarea id="invDescription" name="inv_description" required rows="4"><%= locals.inv_description || '' %></textarea>
  </div>

  <div class="form-group">
    <label for="invImage">Image Path <span class="required">*</span></label>
    <input type="text" id="invImage" name="inv_image" value="<%= locals.inv_image || '' %>">
  </div>

  <div class="form-group">
    <label for="invThumbnail">Thumbnail Path <span class="required">*</span></label>
    <input type="text" id="invThumbnail" name="inv_thumbnail" value="<%= locals.inv_thumbnail || '' %>">
  </div>

  <div class="form-group">
    <label for="invPrice">Price <span class="required">*</span></label>
    <input type="number" id="invPrice" name="inv_price" value="<%= locals.inv_price || '' %>" required min="0">
  </div>

  <div class="form-group">
    <label for="invMiles">Miles <span class="required">*</span></label>
    <input type="number" id="invMiles" name="inv_miles" value="<%= locals.inv_miles || '' %>" required min="0">
  </div>

  <div class="form-group">
    <label for="invColor">Color <span class="required">*</span></label>
    <input type="text" id="invColor" name="inv_color" value="<%= locals.inv_color || '' %>" required>
  </div>

  <p class="required-note"><span class="required">*</span> Required fields</p>
  <button type="submit" class="form-btn">Update Vehicle</button>
  <p class="form-link"><a href="/inv">Back to Management</a></p>
</form>

<% } else { res.redirect('/') } %>
